# CodeTune Backend Environment Variables
# Copy this to .env and fill in your values

# Mode: "demo" (pre-computed traces) or "live" (real inference)
CODETUNE_MODE=demo

# HuggingFace Space (for live inference)
HF_SPACE_URL=https://your-username-codetune-grpo.hf.space/api/predict
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# GitHub (personal access token)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# Google OAuth (for Gmail + Drive)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
